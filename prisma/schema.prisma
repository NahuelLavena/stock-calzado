generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================
// MODELOS PARA MULTI-TENANT
// ============================

model Empresa {
  id        String   @id @default(uuid()) @db.Uuid
  nombre    String
  slug      String   @unique
  logo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usuarios    Usuario[]
  productos   Producto[]
  notificaciones Notificacion[]
}

model Usuario {
  id              String   @id @default(uuid()) @db.Uuid
  email           String   @unique
  nombre          String
  passwordHash    String
  rol             Rol      @default(VENDEDOR)
  empresaId       String   @db.Uuid
  supabaseUserId  String?  @unique @db.Uuid
  puedeEditarStock Boolean @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  empresa     Empresa      @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  movimientos Movimiento[]

  @@index([empresaId])
  @@index([supabaseUserId])
}

// ============================
// MODELOS DE PRODUCTOS
// ============================

model Producto {
  id          String     @id @default(uuid()) @db.Uuid
  sku         String
  nombre      String
  marca       String
  modelo      String
  descripcion String?
  categoria   Categoria  @default(HOMBRES)
  imagenUrl   String?
  precio      Decimal?   @db.Decimal(10, 2)
  activo      Boolean    @default(true)
  empresaId   String     @db.Uuid
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  empresa Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  tallas  Tallaje[]

  @@unique([empresaId, sku])
  @@index([empresaId, activo])
  @@index([marca])
  @@index([categoria])
}

model Tallaje {
  id                   String @id @default(uuid()) @db.Uuid
  talla                String
  color                String
  stock                Int    @default(0)
  stockMinimo          Int    @default(5)
  precioEfectivo       Decimal @db.Decimal(10, 2)
  precioTransferencia  Decimal @db.Decimal(10, 2)
  productoId           String @db.Uuid

  producto    Producto    @relation(fields: [productoId], references: [id], onDelete: Cascade)
  movimientos Movimiento[]

  @@unique([productoId, talla, color])
  @@index([productoId])
  @@index([stock])
}

// ============================
// MODELOS DE MOVIMIENTOS
// ============================

model Movimiento {
  id        String          @id @default(uuid()) @db.Uuid
  tipo      TipoMovimiento
  cantidad  Int
  motivo    String?
  usuarioId String          @db.Uuid
  tallajeId String          @db.Uuid
  createdAt DateTime        @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  tallaje Tallaje @relation(fields: [tallajeId], references: [id], onDelete: Cascade)

  @@index([tallajeId])
  @@index([usuarioId, createdAt])
}

// ============================
// MODELOS DE NOTIFICACIONES
// ============================

model Notificacion {
  id        String   @id @default(uuid()) @db.Uuid
  empresaId String   @db.Uuid
  tipo      String
  titulo    String
  mensaje   String
  leido     Boolean  @default(false)
  createdAt DateTime @default(now())

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([empresaId, leido])
}

// ============================
// ENUMS
// ============================

enum Rol {
  ADMIN
  VENDEDOR
  ALMACENERO
}

enum Categoria {
  HOMBRES
  MUJER
  NINO
  NINA
  URBANAS
  BOTINES
  BEBE
  JUVENIL
  PANTUFLAS
  OJOTAS
}

enum TipoMovimiento {
  ENTRADA
  SALIDA
  AJUSTE_POS
  AJUSTE_NEG
  DEVOLUCION
}
