# Supabase — App Runtime (pooled connections via Supavisor)
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true

# Supabase — Prisma CLI / Migrations (direct connection)
DIRECT_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# Supabase Auth — Public (safe for client-side)
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[ANON-KEY]

# Supabase — Admin (server-only, NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=[SERVICE-ROLE-KEY]

# Offline session HMAC signing (generate a random 32+ char string)
OFFLINE_SESSION_SECRET=[RANDOM-SECRET-STRING]
